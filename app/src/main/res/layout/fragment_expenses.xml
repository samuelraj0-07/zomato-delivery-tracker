<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_expense_mode"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/surface"
        app:tabTextColor="@color/text_secondary"
        app:tabSelectedTextColor="@color/primary"
        app:tabIndicatorColor="@color/primary">
        <com.google.android.material.tabs.TabItem android:text="Fuel"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <com.google.android.material.tabs.TabItem android:text="Service"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <com.google.android.material.tabs.TabItem android:text="TDS"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <com.google.android.material.tabs.TabItem android:text="Cycle"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    </com.google.android.material.tabs.TabLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >

            <!-- FUEL SECTION -->
            <LinearLayout android:id="@+id/section_fuel"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" >

                <androidx.cardview.widget.CardView android:layout_width="match_parent"
                    android:layout_height="wrap_content" app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:padding="16dp" >

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="⛽ Add Fuel Entry"
                            android:textColor="@color/text_primary" android:textSize="15sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxBackgroundColor="@color/surface_variant"
                            app:boxStrokeColor="@color/primary">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_fuel_odometer" android:hint="Odometer Reading (km)" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="horizontal"
                            >
                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                app:boxBackgroundColor="@color/surface_variant"
                                app:boxStrokeColor="@color/primary">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_fuel_price" android:hint="Price/Litre (₹)" android:layout_width="match_parent"
                                    android:layout_height="wrap_content" android:inputType="numberDecimal"
                                    android:textColor="@color/text_primary"/>
                            </com.google.android.material.textfield.TextInputLayout>

                            <com.google.android.material.textfield.TextInputLayout
                                android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1"
                                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                                app:boxBackgroundColor="@color/surface_variant"
                                app:boxStrokeColor="@color/primary">
                                <com.google.android.material.textfield.TextInputEditText
                                    android:id="@+id/et_fuel_amount" android:hint="Amount Spent (₹)" android:layout_width="match_parent"
                                    android:layout_height="wrap_content" android:inputType="numberDecimal"
                                    android:textColor="@color/text_primary"/>
                            </com.google.android.material.textfield.TextInputLayout>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_save_fuel" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="SAVE FUEL ENTRY"
                            app:backgroundTint="@color/primary"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- SERVICE SECTION -->
            <LinearLayout android:id="@+id/section_service"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"  android:visibility="gone">

                <androidx.cardview.widget.CardView android:layout_width="match_parent"
                    android:layout_height="wrap_content" app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:padding="16dp" >

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="🔧 Add Service Entry"
                            android:textColor="@color/text_primary" android:textSize="15sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxBackgroundColor="@color/surface_variant"
                            app:boxStrokeColor="@color/primary">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_service_odometer" android:hint="Odometer Reading (km)" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxBackgroundColor="@color/surface_variant"
                            app:boxStrokeColor="@color/primary">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_service_amount" android:hint="Amount Spent (₹)" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxBackgroundColor="@color/surface_variant"
                            app:boxStrokeColor="@color/primary">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_service_details" android:hint="Details (e.g. Oil change)" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:inputType="textCapSentences"
                                android:textColor="@color/text_primary"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_save_service" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="SAVE SERVICE ENTRY"
                            app:backgroundTint="@color/primary"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- TDS SECTION -->
            <LinearLayout android:id="@+id/section_tds"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"  android:visibility="gone">

                <androidx.cardview.widget.CardView android:layout_width="match_parent"
                    android:layout_height="wrap_content" app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:padding="16dp" >

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="🧾 Add TDS Entry"
                            android:textColor="@color/text_primary" android:textSize="15sp"
                            android:textStyle="bold"/>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxBackgroundColor="@color/surface_variant"
                            app:boxStrokeColor="@color/primary">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_tds_week" android:hint="Week Label (e.g. Week 1 - Apr)" android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="@color/text_primary"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent" android:layout_height="wrap_content"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            app:boxBackgroundColor="@color/surface_variant"
                            app:boxStrokeColor="@color/primary">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/et_tds_amount" android:hint="TDS Amount (₹)" android:layout_width="match_parent"
                                android:layout_height="wrap_content" android:inputType="numberDecimal"
                                android:textColor="@color/text_primary"/>
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_save_tds" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="SAVE TDS"
                            app:backgroundTint="@color/primary"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- CYCLE SECTION -->
            <LinearLayout android:id="@+id/section_cycle"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical"  android:visibility="gone">

                <androidx.cardview.widget.CardView android:layout_width="match_parent"
                    android:layout_height="wrap_content" app:cardBackgroundColor="@color/surface"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:orientation="vertical"
                        android:padding="16dp" >

                        <TextView android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="🔄 Current Service Cycle"
                            android:textColor="@color/text_primary" android:textSize="15sp"
                            android:textStyle="bold"/>

                        <TextView android:id="@+id/tv_cycle_progress"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary" android:textSize="13sp"/>

                        <ProgressBar android:id="@+id/pb_cycle"
                            android:layout_width="match_parent" android:layout_height="8dp"
                            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                            android:progressTint="@color/primary"
                            android:progressBackgroundTint="@color/surface_variant"
                            android:max="100"/>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/divider"/>

                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Earnings this cycle"
                                android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:id="@+id/tv_cycle_earnings"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="@color/positive" android:textSize="14sp"
                                android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Fuel Spent"
                                android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:id="@+id/tv_cycle_fuel"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="@color/negative" android:textSize="14sp"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Service Spent"
                                android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:id="@+id/tv_cycle_service"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textColor="@color/negative" android:textSize="14sp"/>
                        </LinearLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp"
                            android:background="@color/divider"/>

                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Fuel Balance"
                                android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:id="@+id/tv_cycle_fuel_balance"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:orientation="horizontal">
                            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                                android:layout_weight="1" android:text="Service Balance"
                                android:textColor="@color/text_secondary" android:textSize="14sp"/>
                            <TextView android:id="@+id/tv_cycle_service_balance"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:textSize="14sp" android:textStyle="bold"/>
                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btn_new_cycle" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:text="START NEW CYCLE"
                            app:backgroundTint="@color/surface_variant"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="80dp"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
